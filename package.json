{
  "name": "varena",
  "version": "0.4.7",
  "description": "A framework-agnostic, type-safe styling library for building component variants and design tokens, with first-class slots support. Inspired by `stitches`.",
  "homepage": "https://github.com/skordyr/varena#readme",
  "bugs": {
    "url": "https://github.com/skordyr/varena/issues"
  },
  "license": "MIT",
  "author": "skordyr <xyan.sk@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skordyr/varena.git"
  },
  "files": [
    "dist",
    "*.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./design-system": "./dist/design-system.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "oxfmt",
    "lint": "oxlint",
    "build": "tsdown",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.8.0"
}
